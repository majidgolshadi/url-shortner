environment="development"
http_addr="8080"
service_name="url-shortener"
log_level="info"
enable_application_profiler=false

[app_db]
max_open_conn=20
read_timeout_sec=1
write_timeout_sec=1
connection_lifetime_sec=10

[app_db.credential]
host="127.0.0.1:3306"
db_name="url_shortener"
username="root"
password="toor"


[coordination]
node_id="node_1"
range_size=100

[coordination.datastore]
max_open_conn=20
read_timeout_sec=1
write_timeout_sec=1
connection_lifetime_sec=10

[coordination.datastore.credential]
host="127.0.0.1:3306"
db_name="url_shortener"
username="root"
password="toor"

[telemetry]
# Enable or disable OpenTelemetry tracing and metrics collection
enabled=true
# Exporter type: "stdout" for development (prints to console), "otlp" for production (sends to collector)
exporter_type="stdout"
# OTLP collector endpoint (only used when exporter_type="otlp")
otlp_endpoint="localhost:4318"

[opengraph]
# HTTP timeout in seconds when fetching Open Graph metadata from original URLs
fetch_timeout_sec=10

[customer]
# Maximum number of URLs a customer may create
default_budget=100
